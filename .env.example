# =============================================================================
# GROWTHFLARE REVENUE ENGINE — Environment Variables
# Stack confirmed: 2026-06-23 (Free Stack v1.0)
# =============================================================================
# NEVER commit a .env file with real values. This file (.env.example) is safe
# to commit. Copy to .env and fill in real keys — .env is gitignored.
# =============================================================================

# -----------------------------------------------------------------------------
# ENRICHMENT + SIGNAL DETECTION
# Replaces: Extruct, Prospeo, FullEnrich
# -----------------------------------------------------------------------------

# Apollo.io — signal detection, contact enrichment, email sequencing
# Where: apollo.io → Settings → Integrations → API Keys → Create Key
# Scopes: All (People, Organizations, Sequences, Contacts)
# Free tier: 50 export credits/month, 2 active sequences
APOLLO_API_KEY=

# Hunter.io — email verification + supplemental email finding
# Where: hunter.io → Dashboard → API (top nav) → Your API key
# Free tier: 25 searches + 50 verifications/month
HUNTER_API_KEY=

# -----------------------------------------------------------------------------
# EMAIL SEQUENCING + DELIVERABILITY
# Replaces: Instantly, Smartlead
# Note: Apollo handles sequencing on the free stack. No separate tool needed.
# If volume outgrows Apollo free → upgrade to Apollo Starter ($49/month)
# before adding a separate sequencer.
# -----------------------------------------------------------------------------

# Sending domain — custom subdomain, NOT the main selll.io domain
# Status: WARMING (domain warmup started — 21-day minimum)
# Example: team.selll.io
SENDING_DOMAIN=team.selll.io
SENDING_DOMAIN_EMAIL=aaron@team.selll.io

# -----------------------------------------------------------------------------
# CRM
# Replaces: HubSpot paid
# -----------------------------------------------------------------------------

# HubSpot Private App Token (NOT the legacy API key)
# Where: HubSpot → Settings (gear icon) → Integrations → Private Apps
#        → Create a private app → Name: "Growthflare Engine"
#        → Scopes: crm.objects.contacts (read + write)
#                  crm.objects.deals (read + write)
#                  crm.objects.companies (read + write)
#                  crm.schemas.contacts (read)
#        → Create app → copy the Access Token
# Free tier: Unlimited contacts + deals + companies
HUBSPOT_ACCESS_TOKEN=

# HubSpot Portal ID (your account ID — visible in any HubSpot URL: app.hubspot.com/contacts/XXXXXXX/)
HUBSPOT_PORTAL_ID=

# -----------------------------------------------------------------------------
# LINKEDIN AUTOMATION
# Replaces: Expandi
# -----------------------------------------------------------------------------

# Waalaxy — LinkedIn connection requests + DM sequences (T-3/T-2/T-1 pre-engagement)
# Where: waalaxy.com → Settings → Integrations → API (if available on free tier)
# Free tier: 80 connection invitations/month
# Note: Waalaxy operates via Chrome extension, not API. n8n triggers via webhook.
WAALAXY_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# AI — ADB GENERATION, PROPOSALS, LAYER 6 OPTIMIZATION
# -----------------------------------------------------------------------------

# Anthropic Claude API — ADB, reply classification, proposals, optimization reports
# Where: console.anthropic.com → API Keys → Create Key
# Cost at launch volume (~50 ADBs/month): ~$0.20/month. Treat as free.
ANTHROPIC_API_KEY=

# Claude model to use for ADB + proposals (latest recommended)
CLAUDE_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# WORKFLOW ORCHESTRATION
# Replaces: n8n Cloud ($50/month)
# -----------------------------------------------------------------------------

# n8n self-hosted instance URL (Railway deployment)
# Setup: railway.app → New Project → Deploy from template → n8n
# Free tier: 500 execution hours/month (more than enough for launch)
N8N_INSTANCE_URL=

# n8n API key (Settings → API → Create API Key inside your n8n instance)
N8N_API_KEY=

# Slack webhook for all engine alerts (HOT reply, DHS stall, CHS alert, Layer 6 report)
# Where: api.slack.com → Your Apps → Create App → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# VIDEO OUTREACH
# Replaces: HeyGen (for Ghost Positive — Loom is better here anyway)
# -----------------------------------------------------------------------------

# Loom — Ghost Positive video re-activation
# Where: loom.com → Settings → My Account → API (if using Loom API for n8n trigger)
# Free tier: Unlimited videos, 5-min limit per video
# Note: Ghost Positive videos are recorded manually by Aaron then sent via n8n link.
# No API key required for manual Ghost Positive workflow.
LOOM_API_KEY=

# -----------------------------------------------------------------------------
# PROPOSALS + CONTRACTS
# Replaces: PandaDoc paid, DocuSign paid
# -----------------------------------------------------------------------------

# PandaDoc — proposal generation and tracking
# Where: pandadoc.com → Settings → Integrations → API → Generate Key
# Free tier: Unlimited documents, no eSign (use DocuSign free for signing)
PANDADOC_API_KEY=

# DocuSign — contract signing
# Where: developers.docusign.com → Apps and Keys → Create App → Integration Key
# Free tier: 3 envelopes/month
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# =============================================================================
# DEPRECATED — Original stack (replaced by free stack 2026-06-23)
# Remove these once free stack is confirmed working.
# =============================================================================

# EXTRUCT_API_TOKEN=        → replaced by APOLLO_API_KEY
# PROSPEO_API_KEY=          → replaced by APOLLO_API_KEY + HUNTER_API_KEY
# FULLENRICH_API_KEY=       → replaced by APOLLO_API_KEY + HUNTER_API_KEY
# INSTANTLY_API_KEY=        → replaced by APOLLO_API_KEY (sequences)
# EXPANDI_API_KEY=          → replaced by WAALAXY_WEBHOOK_URL
# HEYGEN_API_KEY=           → replaced by LOOM_API_KEY (Ghost Positive)
